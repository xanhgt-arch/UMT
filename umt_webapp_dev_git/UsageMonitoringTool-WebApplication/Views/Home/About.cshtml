<div class="row" style="margin-top: 20px;">
    <h2 style="margin-left:50px; font-family: 'Times New Roman', Times, serif; font-size:30px;">Utilization Over the Year </h2>
</div>

@{

    List<SelectListItem> listItems3 = new List<SelectListItem>();
    listItems3.Add(new SelectListItem
    {
        Text = "CATIA",
        Value = "CATIA"
    });
    listItems3.Add(new SelectListItem
    {
        Text = "NX",
        Value = "NX"
    });

    List<SelectListItem> listItems = ViewBag.listItems;
    List<SelectListItem> listDomains = ViewBag.listitems2;
    List<SelectListItem> listRegions = ViewBag.listitems3;
    string xmlpath = "";
    System.Xml.XmlDocument xmlfile = new System.Xml.XmlDocument();
    string[] removeapps = { "CLIPS AND ADAPTORS", "HIT", "FLANGE THICKNESS", "TEST_APP" };
    List<SelectListItem> Finalapps = new List<SelectListItem>();

    string formattedStr2 = string.Empty;
    string newname = string.Empty;
    string newValue = string.Empty;

    System.Xml.XmlElement nodesfrmConfig;
    xmlpath = AppDomain.CurrentDomain.SetupInformation.ConfigurationFile;

    if (System.IO.File.Exists(xmlpath))
    {
        xmlfile.Load(xmlpath);
    }


    foreach (var item in listItems)
    {
        bool existdata = false;
        SelectListItem objSel = new SelectListItem();
        if (item.Text.ToUpper() == "ALL")
        {
            continue;
            //objSel.Selected = true;
        }
        if (removeapps.Contains(item.Text.ToUpper()))
        {
            continue;
        }
        formattedStr2 = item.Text.Replace(" ", "").Replace("_", "").ToUpper();
        nodesfrmConfig = xmlfile.SelectSingleNode("/configuration/myCustomElement") as System.Xml.XmlElement;
        System.Xml.XmlNodeList elemlst = nodesfrmConfig.GetElementsByTagName(formattedStr2);
        if (elemlst != null && elemlst.Count > 0)
        {
            objSel.Text = elemlst.Item(0).InnerText;
            objSel.Value = item.Value;
        }
        else
        {
            objSel.Text = item.Text;
            objSel.Value = item.Value;
        }

        if (Finalapps.Count > 0)
        {
            int index = 0;
            foreach (var x in Finalapps)
            {
                if (x.Text == objSel.Text)
                {
                    Finalapps[index].Value = Finalapps[index].Value + "," + objSel.Value;
                    existdata = true;
                    break;
                }
                index = index + 1;
            }
        }
        if (existdata == false)
        {
            Finalapps.Add(objSel);
        }

    }
    var Finalapps1 = Finalapps.OrderBy(x => x.Text).ToList();
    List<SelectListItem> appDataList = new List<SelectListItem>();
    appDataList.Add(new SelectListItem
    {
        Text = "SMART CVT",
        Value = "SMART CVT"
    });
    appDataList.Add(new SelectListItem
    {
        Text = "POINT CHART",
        Value = "POINT CHART"
    });
    appDataList.Add(new SelectListItem
    {
        Text = "PROFILE CHECKER",
        Value = "PROFILE CHECKER"
    });
    appDataList.Add(new SelectListItem
    {
        Text = "FILE MANAGER",
        Value = "FILE MANAGER"
    });
    appDataList.Add(new SelectListItem
    {
        Text = "MULTI 3D",
        Value = "MULTI 3D"
    });
    appDataList.Add(new SelectListItem
    {
        Text = "SECTION MANAGER",
        Value = "SECTION MANAGER"
    });
    appDataList.Add(new SelectListItem
    {
        Text = "3D TRIM",
        Value = "3D TRIM"
    });
    List<SelectListItem> dataTypeList = new List<SelectListItem>();
    dataTypeList.Add(new SelectListItem
    {
        Text = "PRODUCTION DATA",
        Value = "PRODUCTION DATA"
    });
    dataTypeList.Add(new SelectListItem
    {
        Text = "TEST DATA",
        Value = "TEST DATA"
    });
    List<SelectListItem> listItems1 = new List<SelectListItem>();
    listItems1.Add(new SelectListItem
    {
        Text = "FLUIDS",
        Value = "FLUIDS"
    });
    listItems1.Add(new SelectListItem
    {
        Text = "SEALING",
        Value = "SEALING"
    });
    listItems1.Add(new SelectListItem
    {
        Text = "GENERAL",
        Value = "GENERAL"
    });

    List<SelectListItem> listItems2 = listRegions.OrderBy(x => x.Text).ToList();
    List<SelectListItem> listHardware = new List<SelectListItem>();

    listHardware.Add(new SelectListItem
    {
        Text = "VDI",
        Value = "VDI"
    });
    listHardware.Add(new SelectListItem
    {
        Text = "Non-VDI",
        Value = "Non-VDI"
    });

    var listDomain = listDomains.OrderBy(x => x.Text).ToList();

}


