    function wireRegionDomainMultiSelect(config) {

        var regionSelectId = config.regionSelectId;
        var regionInputName = config.regionInputName;
        var domainSelectId = config.domainSelectId;
        var domainInputName = config.domainInputName;

        function destroyDomainMultiCheckBox() {
            $('.MultiCheckBox').filter(function () {
                return $(this).next('.MultiCheckBoxDetail')
                    .find('input[name="' + domainInputName + '"]').length > 0;
            }).remove();

            $('.MultiCheckBoxDetail').filter(function () {
                return $(this)
                    .find('input[name="' + domainInputName + '"]').length > 0;
            }).remove();
        }

        function recreateDomainMultiCheckBox() {
            $('#' + domainSelectId).CreateMultiCheckBox({
                name: domainInputName,
                width: '200px',
                defaultText: 'All',
                height: '250px'
            });
        }

        // Region change listener
        $(document).on('change', 'input[name="' + regionInputName + '"]', function () {

            var selectedRegions = [];

            $('input[name="' + regionInputName + '"]:checked').each(function () {
                if ($(this).val() !== 'ALL') {
                    selectedRegions.push($(this).val());
                }
            });

            destroyDomainMultiCheckBox();
            $('#' + domainSelectId).empty();

            if (selectedRegions.length === 0) {
                recreateDomainMultiCheckBox();
                return;
            }

            $.ajax({
                url: config.ajaxUrl,
                type: 'POST',
                traditional: true,
                data: { regions: selectedRegions },
                success: function (data) {

                    $.each(data, function (i, item) {
                        $('#' + domainSelectId).append(
                            $('<option></option>')
                                .val(item.Value)
                                .text(item.Text)
                        );
                    });

                    recreateDomainMultiCheckBox();
                }
            });
        });
    }


